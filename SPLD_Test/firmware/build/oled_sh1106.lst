  39:Core/Src/oled_sh1106.c ****   WriteCmd(0xAE); /* display off */
  40:Core/Src/oled_sh1106.c ****   WriteCmd(0xA8); WriteCmd(0x3F); /* multiplex 64-1 */
  41:Core/Src/oled_sh1106.c ****   WriteCmd(0xD3); WriteCmd(0x00); /* display offset */
  42:Core/Src/oled_sh1106.c ****   WriteCmd(0x40); /* display start line 0 */
