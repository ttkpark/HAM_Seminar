 104:Core/Src/main.c ****   /* Layout: 5 columns for monitor. Centers ~14,38,62,86,110 */
 105:Core/Src/main.c ****   #define CPLD_N      5
 106:Core/Src/main.c ****   #define CPLD_CX(i)  (14 + (i) * 24)
 107:Core/Src/main.c ****   #define CPLD_CY     26
 108:Core/Src/main.c ****   #define CPLD_R      5
 109:Core/Src/main.c ****   #define LABEL_Y     10
 110:Core/Src/main.c ****   #define DIGIT_Y     40
 111:Core/Src/main.c ****   #define BOX_Y0      18
 112:Core/Src/main.c ****   #define BOX_Y1      52
 113:Core/Src/main.c **** 
 114:Core/Src/main.c ****   /* Static frame: border + title + labels (28,29,31,34,37) - labels centered under icons */
 115:Core/Src/main.c ****   OLED_DrawRect(0, 0, OLED_WIDTH - 1, OLED_HEIGHT - 1);
 116:Core/Src/main.c ****   OLED_DrawString(34, 0, "CPLD MON");  /* space between CPLD and MON */
 117:Core/Src/main.c ****   OLED_DrawString(CPLD_CX(0) - 6, LABEL_Y, "28");  /* 4px right: was 4, now 8 */
 118:Core/Src/main.c ****   OLED_DrawString(CPLD_CX(1) - 6, LABEL_Y, "29");  /* was 28, now 32 */
 119:Core/Src/main.c ****   OLED_DrawString(CPLD_CX(2) - 6, LABEL_Y, "31");  /* was 52, now 56 */
 120:Core/Src/main.c ****   OLED_DrawString(CPLD_CX(3) - 6, LABEL_Y, "34");  /* was 76, now 80 */
 121:Core/Src/main.c ****   OLED_DrawString(CPLD_CX(4) - 6, LABEL_Y, "37");  /* was 100, now 104 */
 122:Core/Src/main.c ****   OLED_Refresh();
 123:Core/Src/main.c **** 
 124:Core/Src/main.c ****   /* USER CODE END 2 */
 125:Core/Src/main.c **** 
 126:Core/Src/main.c ****   /* Infinite loop */
 127:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 128:Core/Src/main.c ****   while (1)
 129:Core/Src/main.c ****   {
 130:Core/Src/main.c ****     /* USER CODE END WHILE */
 131:Core/Src/main.c **** 
 132:Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 133:Core/Src/main.c ****     GPIO_PinState s[CPLD_N];
 134:Core/Src/main.c ****     s[0] = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_2);
 135:Core/Src/main.c ****     s[1] = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_3);
 136:Core/Src/main.c ****     s[2] = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_10);
 137:Core/Src/main.c ****     s[3] = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_12);
 138:Core/Src/main.c ****     s[4] = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_15);
 139:Core/Src/main.c **** 
 140:Core/Src/main.c ****     for (int i = 0; i < CPLD_N; i++) {
 141:Core/Src/main.c ****       uint8_t cx = CPLD_CX(i);
 142:Core/Src/main.c ****       OLED_ClearRect(cx - 11, BOX_Y0, cx + 11, BOX_Y1);
 143:Core/Src/main.c ****       OLED_DrawCircle(cx, CPLD_CY, CPLD_R, (s[i] == GPIO_PIN_SET));
 144:Core/Src/main.c ****       OLED_DrawChar(cx - 3, DIGIT_Y, (s[i] == GPIO_PIN_SET) ? '1' : '0');  /* 6px char: center at c
 145:Core/Src/main.c ****     }
 146:Core/Src/main.c **** 
 147:Core/Src/main.c ****     OLED_Refresh();
